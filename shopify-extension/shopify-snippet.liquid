<!-- ═══════════════════════════════════════════════════════════════
     Dual Name 3D Customizer — Shopify Product Page Snippet
     Preview Button + Modal: reads APO Name inputs → 3D preview

     HOW TO USE:
     1. In Shopify Admin → Online Store → Themes → Customize
     2. On your product page template, add a "Custom Liquid" block
     3. Paste this entire file into the Custom Liquid block
     4. Set EMBED_URL below to your deployed customer.html URL

     VARIANT MATCHING:
     Variants must be "Color / Packing" combos, e.g. "Black / Cartoon Box"
     ═══════════════════════════════════════════════════════════════ -->

<!-- Preview 3D Button — placed inline on product page -->
<button id="dn-preview-btn" class="dn-preview-btn" type="button">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
    <circle cx="12" cy="12" r="3"/>
  </svg>
  Preview 3D
</button>

<!-- Modal overlay -->
<div id="dn-modal-overlay" class="dn-modal-overlay dn-hidden">
  <div class="dn-modal">
    <div class="dn-modal-header">
      <span class="dn-modal-title">3D Preview</span>
      <button id="dn-modal-close" class="dn-modal-close" type="button">&times;</button>
    </div>
    <div class="dn-modal-body">
      <iframe id="dn-iframe" allow="autoplay" loading="lazy"></iframe>
      <div id="dn-modal-loading" class="dn-modal-loading">
        <div class="dn-spinner"></div>
        <span>Generating your 3D preview...</span>
      </div>
    </div>
    <div id="dn-modal-names" class="dn-modal-names"></div>
    <div class="dn-modal-note">The color shown is for preview purposes only. Your product will be made in the color you select.</div>
  </div>
</div>

<style>
  /* ── Preview Button ── */
  .dn-preview-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 20px;
    margin-top: 10px;
    background: #fff;
    color: #121212;
    border: 2px solid #121212;
    border-radius: 0;
    font-family: Poppins, sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.04rem;
    text-transform: uppercase;
  }

  .dn-preview-btn:hover {
    background: #121212;
    color: #fff;
  }

  .dn-preview-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Modal Overlay ── */
  .dn-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: dnFadeIn 0.25s ease;
  }

  .dn-modal-overlay.dn-hidden {
    display: none !important;
  }

  @keyframes dnFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── Modal Box ── */
  .dn-modal {
    background: #fff;
    width: 100%;
    max-width: 600px;
    max-height: 85vh;
    border-radius: 0;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    animation: dnSlideUp 0.3s ease;
  }

  @keyframes dnSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Modal Header ── */
  .dn-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e5e5e5;
  }

  .dn-modal-title {
    font-family: Poppins, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #121212;
    letter-spacing: 0.04rem;
  }

  .dn-modal-close {
    background: none;
    border: none;
    font-size: 28px;
    color: #666;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.2s;
  }

  .dn-modal-close:hover {
    color: #121212;
  }

  /* ── Modal Body (iframe) ── */
  .dn-modal-body {
    position: relative;
    width: 100%;
    height: 420px;
  }

  .dn-modal-body iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* ── Loading state inside modal ── */
  .dn-modal-loading {
    position: absolute;
    inset: 0;
    background: rgba(245, 245, 245, 0.95);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    z-index: 5;
  }

  .dn-modal-loading.dn-hidden { display: none; }

  .dn-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid rgba(0,0,0,0.08);
    border-top-color: #EC5677;
    border-radius: 50%;
    animation: dnSpin 0.7s linear infinite;
  }

  @keyframes dnSpin { to { transform: rotate(360deg); } }

  .dn-modal-loading span {
    font-family: Poppins, sans-serif;
    font-size: 13px;
    color: #666;
    letter-spacing: 0.04rem;
  }

  /* ── Names display ── */
  .dn-modal-names {
    padding: 12px 20px;
    border-top: 1px solid #e5e5e5;
    font-family: Poppins, sans-serif;
    font-size: 14px;
    color: #121212;
    text-align: center;
    font-weight: 600;
    letter-spacing: 0.06rem;
    text-transform: uppercase;
  }

  /* ── Note ── */
  .dn-modal-note {
    padding: 10px 20px;
    font-family: Poppins, sans-serif;
    font-size: 12px;
    color: #888;
    text-align: center;
    line-height: 1.4;
    border-top: 1px solid #e5e5e5;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .dn-modal-overlay { padding: 10px; }
    .dn-modal { max-height: 90vh; }
    .dn-modal-body { height: 340px; }
    .dn-preview-btn { font-size: 14px; padding: 12px 16px; }
  }
</style>

<script>
(function() {
  'use strict';

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  CONFIGURATION                                               ║
  // ╚═══════════════════════════════════════════════════════════════╝

  var EMBED_URL = 'https://dual-letter-illusion.onrender.com/customer.html';

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  FIND APO NAME INPUTS                                        ║
  // ╚═══════════════════════════════════════════════════════════════╝

  function findNameInputs() {
    // APO creates inputs dynamically — find them by label text
    var allLabels = document.querySelectorAll('label');
    var name1Input = null;
    var name2Input = null;

    for (var i = 0; i < allLabels.length; i++) {
      var label = allLabels[i];
      var text = (label.textContent || '').trim().toLowerCase().replace(/\*+$/, '').trim();

      if (text === 'name 1' || text === 'name1') {
        // Find the input associated with this label
        var forId = label.getAttribute('for');
        if (forId) {
          name1Input = document.getElementById(forId);
        }
        if (!name1Input) {
          // Try next sibling or parent's next input
          name1Input = label.parentElement.querySelector('input[type="text"], input:not([type])');
        }
      }

      if (text === 'name 2' || text === 'name2') {
        var forId2 = label.getAttribute('for');
        if (forId2) {
          name2Input = document.getElementById(forId2);
        }
        if (!name2Input) {
          name2Input = label.parentElement.querySelector('input[type="text"], input:not([type])');
        }
      }
    }

    // Fallback: search by placeholder
    if (!name1Input || !name2Input) {
      var allInputs = document.querySelectorAll('input[type="text"], input:not([type])');
      for (var j = 0; j < allInputs.length; j++) {
        var inp = allInputs[j];
        var ph = (inp.placeholder || '').toLowerCase();
        var nm = (inp.name || '').toLowerCase();
        if (!name1Input && (ph.indexOf('name 1') >= 0 || nm.indexOf('name_1') >= 0 || nm.indexOf('name1') >= 0)) {
          name1Input = inp;
        }
        if (!name2Input && (ph.indexOf('name 2') >= 0 || nm.indexOf('name_2') >= 0 || nm.indexOf('name2') >= 0)) {
          name2Input = inp;
        }
      }
    }

    return { name1Input: name1Input, name2Input: name2Input };
  }

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  ELEMENTS                                                    ║
  // ╚═══════════════════════════════════════════════════════════════╝

  var previewBtn = document.getElementById('dn-preview-btn');
  var modalOverlay = document.getElementById('dn-modal-overlay');
  var modalClose = document.getElementById('dn-modal-close');
  var iframe = document.getElementById('dn-iframe');
  var modalLoading = document.getElementById('dn-modal-loading');
  var modalNames = document.getElementById('dn-modal-names');

  var iframeReady = false;
  var pendingNames = null;

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  PREVIEW BUTTON CLICK                                        ║
  // ╚═══════════════════════════════════════════════════════════════╝

  previewBtn.addEventListener('click', function() {
    var inputs = findNameInputs();

    var name1 = inputs.name1Input ? inputs.name1Input.value.trim() : '';
    var name2 = inputs.name2Input ? inputs.name2Input.value.trim() : '';

    if (!name1 || !name2) {
      alert('Please enter both Name 1 and Name 2 first.');
      return;
    }

    // Show modal
    modalOverlay.classList.remove('dn-hidden');
    modalLoading.classList.remove('dn-hidden');
    modalNames.textContent = name1 + '  ♥  ' + name2;
    document.body.style.overflow = 'hidden';

    // Load iframe if not loaded yet
    if (!iframe.src || iframe.src === 'about:blank' || iframe.src.indexOf(EMBED_URL) === -1) {
      iframe.src = EMBED_URL;
    }

    // Send names to iframe
    if (iframeReady) {
      sendNamesToIframe(name1, name2);
    } else {
      pendingNames = { name1: name1, name2: name2 };
    }
  });

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  CLOSE MODAL                                                 ║
  // ╚═══════════════════════════════════════════════════════════════╝

  function closeModal() {
    modalOverlay.classList.add('dn-hidden');
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', closeModal);

  modalOverlay.addEventListener('click', function(e) {
    if (e.target === modalOverlay) closeModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modalOverlay.classList.contains('dn-hidden')) {
      closeModal();
    }
  });

  // ╔═══════════════════════════════════════════════════════════════╗
  // ║  IFRAME COMMUNICATION                                        ║
  // ╚═══════════════════════════════════════════════════════════════╝

  function sendNamesToIframe(name1, name2) {
    if (iframe && iframe.contentWindow) {
      iframe.contentWindow.postMessage({
        source: 'dual-name-parent',
        type: 'set-names',
        name1: name1,
        name2: name2
      }, '*');
    }
  }

  window.addEventListener('message', function(event) {
    var data = event.data;
    if (!data || data.source !== 'dual-name') return;

    if (data.type === 'iframe-ready') {
      iframeReady = true;
      // If names were pending, send them now
      if (pendingNames) {
        sendNamesToIframe(pendingNames.name1, pendingNames.name2);
        pendingNames = null;
      }
    }

    if (data.type === 'preview-loading') {
      modalLoading.classList.remove('dn-hidden');
    }

    if (data.type === 'preview-ready') {
      modalLoading.classList.add('dn-hidden');
    }

    if (data.type === 'preview-error') {
      modalLoading.classList.add('dn-hidden');
      alert('Failed to generate preview: ' + (data.message || 'Unknown error'));
    }
  });

})();
</script>
